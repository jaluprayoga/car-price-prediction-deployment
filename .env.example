# Google Cloud Storage Settings
# Path to service account JSON key file (relative to deployment root or absolute)
GOOGLE_APPLICATION_CREDENTIALS=your-gcp-key.json

# Google Cloud Storage Bucket Name
GCS_BUCKET_NAME=your-gcs-bucket-name

# Security & Authentication Settings
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=your_secure_jwt_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Keys (comma-separated list for machine-to-machine access)
API_KEYS=api-key-1,api-key-2

# Dummy User Credentials (automatically seeded into local database on startup)
DUMMY_USER_USERNAME=your_dummy_username_here
DUMMY_USER_PASSWORD=your_dummy_password_here

# MLflow Configurations
MLFLOW_TRACKING_URI=http://localhost:5000
# Optional MLflow auth credentials (if using a remote MLflow server e.g. DagsHub)
DAGSHUB_TOKEN=your-dagshub-token
DAGSHUB_REPO_OWNER=your-dagshub-username
DAGSHUB_REPO_NAME=your-dagshub-repo-name

# Logging settings
LOG_LEVEL=INFO
